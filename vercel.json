{
  "version": 2,
  "builds": [
    {
      "src": "pubspec.yaml",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "build/web"
      }
    }
  ],
  "routes": [
    {
      "src": "/.*",
      "dest": "build/web/index.html"
    }
  ],
  "installCommand": "bash ./install_flutter.sh && flutter pub get",
  "buildCommand": "flutter build web --release"
}