{
  "builds": [
    {
      "src": "**/pubspec.yaml",
      "use": "@n4b/vercel-flutter",
      "config": {
        "flutterVersion": "3.22.0"
      }
    }
  ],
  "installCommand": "flutter doctor",
  "buildCommand": "flutter build web --web-renderer html --no-sound-null-safety --release",
  "outputDirectory": "build/web"
}